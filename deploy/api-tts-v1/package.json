{
  "name": "capcut-tts",
  "description": "Backend-only CapCut TTS wrapper for text and DOCX to MP3 workflows",
  "version": "2.0.0",
  "author": "",
  "keywords": [
    "typescript",
    "expressjs",
    "capcut",
    "tts",
    "docx"
  ],
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "capcut:extract": "tsx src/scripts/extractCapCutBundles.ts",
    "capcut:qr-login": "tsx src/tools/capcutQrLogin.ts",
    "capcut:qr-exe": "npm run build && pkg dist/tools/capcutQrLogin.js --targets node22-win-x64 --output dist/capcut-qr-login.exe",
    "telegram:chat-id": "tsx src/tools/telegramChatId.ts",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "lint:fix": "npm run lint -- --fix",
    "wintest": "title %npm_config_id% && npm run build && node --disable-warning=ExperimentalWarning ./dist/index.js",
    "test": "npm run build",
    "winstart": "title %npm_config_id% && node --disable-warning=ExperimentalWarning ./dist/index.js",
    "start": "node --disable-warning=ExperimentalWarning ./dist/index.js"
  },
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "tslog": "^4.10.2",
    "ws": "^8.14.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.5.6",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@yao-pkg/pkg": "^6.18.2",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
