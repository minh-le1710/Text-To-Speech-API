# CapCut Web Endpoint
CAPCUT_WEB_URL=https://www.capcut.com
CAPCUT_EDIT_API_URL=https://edit-api-sg.capcut.com
CAPCUT_LOGIN_HOST=https://login-row.www.capcut.com
CAPCUT_FALLBACK_LOGIN_HOST=https://login.us.capcut.com

# Optional fallback password login.
# Preferred flow: run npm run capcut:qr-login and keep the session file.
CAPCUT_EMAIL=
CAPCUT_PASSWORD=

# Locale / Device
CAPCUT_LOCALE=vi-VN
CAPCUT_PAGE_LOCALE=vi-vn
CAPCUT_REGION=VN
CAPCUT_STORE_COUNTRY_CODE=vn
CAPCUT_REGION_FALLBACK_ENABLED=true
CAPCUT_FALLBACK_LOCALE=nl-NL
CAPCUT_FALLBACK_PAGE_LOCALE=nl-nl
CAPCUT_FALLBACK_REGION=NL
CAPCUT_FALLBACK_STORE_COUNTRY_CODE=nl
# CAPCUT_DEVICE_ID=
# CAPCUT_TDID=
# CAPCUT_VERIFY_FP=

# Bundle config cache
CAPCUT_BUNDLE_CONFIG_PATH=data/capcut-bundle-config.json

# Default fallback category id
CAPCUT_VOICE_CATEGORY_ID=21699

# Session cache
CAPCUT_SESSION_STORE_PATH=data/capcut-session.json
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36

# Node Setting
LOG_LEVEL=info
ERROR_HANDLE=true

# Server Setting
HOST=0.0.0.0
PORT=8080
CORS_POLICY_ORIGIN=*

# Background session validation interval (minutes)
SESSION_REFRESH_INTERVAL_MINUTES=30

# DOCX -> MP3 API
DOCX_MAX_FILE_MB=100
TTS_MAX_CHARS_PER_CHUNK=320
DOCX_JOB_DB_PATH=data/docx-jobs.sqlite
DOCX_JOB_WORKDIR=data/docx-jobs

# Telegram notifications
# Create a bot with BotFather, message the bot once, then run:
# npm run telegram:chat-id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_QR_LOGIN_ENABLED=true
TELEGRAM_DOCX_NOTIFICATIONS=true
TELEGRAM_QR_LOGIN_TIMEOUT_SECONDS=300
TELEGRAM_QR_POLL_INTERVAL_MS=2500
TELEGRAM_DOCX_UPLOADS_ENABLED=true
TELEGRAM_DOCX_DEFAULT_TYPE=0
TELEGRAM_DOCX_DEFAULT_VOICE=nguon nho ngot ngao
TELEGRAM_DOCX_POLL_TIMEOUT_SECONDS=25
TELEGRAM_DOCX_STATUS_INTERVAL_SECONDS=60

# Legacy TTS Endpoint (/legacy/synthesize)
LEGACY_CAPCUT_API_URL=https://edit-api-sg.capcut.com/lv/v1
LEGACY_BYTEINTL_API_URL=wss://sami-sg1.byteintlapi.com/internal/api/v1
# LEGACY_DEVICE_TIME=
# LEGACY_SIGN=
LEGACY_TOKEN_INTERVAL=6
